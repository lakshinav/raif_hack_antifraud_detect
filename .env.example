# Скопируй в .env и подставь свой ключ: cp .env.example .env
# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...
# Лучший primary по pipeline sweep + быстрый secondary + сильный judge для спорных кейсов
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_PRIMARY_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_SECONDARY_MODEL=openai/gpt-5.4-mini
OPENROUTER_JUDGE_MODEL=openai/gpt-5.5
OPENROUTER_TIMEOUT_SECONDS=4.2
RISK_CACHE_SIZE=1024
RISK_CONFIDENCE_THRESHOLD=0.78
CLEAN_CONFIDENCE_THRESHOLD=0.84
RISK_FAST_ACCEPT_CONFIDENCE_THRESHOLD=0.82
RISK_SECONDARY_CONFIDENCE_THRESHOLD=0.86
RISK_AGREEMENT_CONFIDENCE_THRESHOLD=0.74
CLEAN_USER_MESSAGE_FREQUENCY_THRESHOLD=0.30
RECOVERY_REVIEW_USER_MESSAGE_FREQUENCY=0.50
RECOVERY_REVIEW_MIN_MESSAGES=12
LOG_LEVEL=INFO

# HF-режим (опционально): токен Hugging Face для локальной NLI-модели
# HF_TOKEN=hf_...
