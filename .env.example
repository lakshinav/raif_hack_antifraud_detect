# Скопируй в .env и подставь свой ключ: cp .env.example .env
# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...
# Быстрый primary + сильный secondary/judge для спорных кейсов
OPENROUTER_MODEL=anthropic/claude-opus-4.8-fast
OPENROUTER_PRIMARY_MODEL=anthropic/claude-opus-4.8-fast
OPENROUTER_SECONDARY_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_JUDGE_MODEL=anthropic/claude-opus-4.8
OPENROUTER_TIMEOUT_SECONDS=4.2
RISK_CACHE_SIZE=1024
RISK_CONFIDENCE_THRESHOLD=0.78
CLEAN_CONFIDENCE_THRESHOLD=0.84
RISK_FAST_ACCEPT_CONFIDENCE_THRESHOLD=0.88
RISK_SECONDARY_CONFIDENCE_THRESHOLD=0.86
RISK_AGREEMENT_CONFIDENCE_THRESHOLD=0.74
ENABLE_CLEAN_ROLE_DISTRIBUTION_CHECK=true
ENABLE_LOCAL_STATISTICAL_RULES_CHECK=false
ENABLE_LOCAL_REGEX_RULES_CHECK=false
CLEAN_USER_MESSAGE_FREQUENCY_THRESHOLD=0.30
RECOVERY_REVIEW_USER_MESSAGE_FREQUENCY=0.50
RECOVERY_REVIEW_MIN_MESSAGES=12
LOG_LEVEL=INFO

# HF-режим (опционально): токен Hugging Face для локальной NLI-модели
# HF_TOKEN=hf_...
