# Скопируй в .env и подставь свой ключ: cp .env.example .env
# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...
# Быстрый primary + сильный независимый secondary + самый сильный judge для спорных кейсов
OPENROUTER_MODEL=openai/gpt-5.4-mini
OPENROUTER_PRIMARY_MODEL=openai/gpt-5.4-mini
OPENROUTER_SECONDARY_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_JUDGE_MODEL=openai/gpt-5.5
OPENROUTER_TIMEOUT_SECONDS=4.2
RISK_CACHE_SIZE=1024
RISK_CONFIDENCE_THRESHOLD=0.88
CLEAN_CONFIDENCE_THRESHOLD=0.76
RISK_SECONDARY_CONFIDENCE_THRESHOLD=0.90
RISK_AGREEMENT_CONFIDENCE_THRESHOLD=0.82
LOG_LEVEL=INFO

# HF-режим (опционально): токен Hugging Face для локальной NLI-модели
# HF_TOKEN=hf_...
