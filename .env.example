# Скопируй в .env и подставь свой ключ: cp .env.example .env
# Ключ OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...
# Лучший primary по локальному sweep + быстрый secondary + сильный judge для спорных кейсов
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_PRIMARY_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_SECONDARY_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_JUDGE_MODEL=openai/gpt-5.5
OPENROUTER_TIMEOUT_SECONDS=4.2
RISK_CACHE_SIZE=1024
RISK_CONFIDENCE_THRESHOLD=0.78
CLEAN_CONFIDENCE_THRESHOLD=0.78
RISK_FAST_ACCEPT_CONFIDENCE_THRESHOLD=0.86
RISK_SECONDARY_CONFIDENCE_THRESHOLD=0.86
RISK_AGREEMENT_CONFIDENCE_THRESHOLD=0.78
LOG_LEVEL=INFO

# HF-режим (опционально): токен Hugging Face для локальной NLI-модели
# HF_TOKEN=hf_...
